{
  "diff_view_style": "split",
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
  },
  "collaboration_panel": {
    "button": true,
    "dock": "right",
  },
  "agent": {
    "single_file_review": true,
    "button": true,
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
    "anthropic_retention": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "agent_servers": {
    "codex-acp": {
      "default_config_options": {
        "fast-mode": "off",
      },
      "type": "registry",
    },
  },
  "base_keymap": "JetBrains",
  "vim_mode": false,
  "helix_mode": true,
  "theme": "Kanagawa Dragon",
  "lsp": {
    "jdtls": {
      "settings": {
        "jdk_auto_download": true,
        "lombok_support": true,
      },
    },
  },
}
