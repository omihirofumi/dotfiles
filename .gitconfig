[user]
	name = omihirofumi
	email = 99390907+omihirofumi@users.noreply.github.com

[core]
	excludesFile = ~/.config/git/ignore
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	dark = true

[merge]
	conflictStyle = zdiff3

[rebase]
	autoSquash = true

[url "git@github.com:"]
	pushInsteadOf = https://github.com/

[ghq]
	root = ~/ghq/hobby

[ghq "https://github.com/alpdr/"]
	root = ~/ghq/work
